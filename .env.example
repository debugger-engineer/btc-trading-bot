# --- Database (Neon PostgreSQL) ---
# Use the connection string from your Neon project dashboard.
# Prod: use the "production" branch endpoint
# Dev:  create a "dev" branch in Neon console and use its endpoint
DATABASE_URL=postgresql://neondb_owner:<password>@<endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
